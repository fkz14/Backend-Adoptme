{
  "openapi": "3.0.0",
  "info": {
    "title": "Adoptme API",
    "version": "1.0.0",
    "description": "API para la gestión de usuarios, mascotas y adopciones. Documentación del módulo Users (OpenAPI 3.0)"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api/users": {
      "get": {
        "summary": "Obtener todos los usuarios",
        "description": "Retorna la lista completa de usuarios (sin contraseñas).",
        "responses": {
          "200": {
            "description": "Lista de usuarios",
            "content": {
              "application/json": {
                "example": {
                  "status": "success",
                  "payload": [
                    {
                      "_id": "64b2d8f9e9a1b2c3d4e5f678",
                      "first_name": "Alejo",
                      "last_name": "Perez",
                      "email": "alejo@example.com",
                      "role": "user",
                      "pets": []
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Error del servidor",
            "content": { "application/json": { "example": { "status": "error", "error": "Internal Server Error" } } }
          }
        }
      }
    },
    "/api/users/{uid}": {
      "parameters": [
        {
          "name": "uid",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "ID del usuario (Mongo ObjectId)"
        }
      ],
      "get": {
        "summary": "Obtener un usuario por ID",
        "description": "Retorna un usuario específico por su ID.",
        "responses": {
          "200": {
            "description": "Usuario encontrado",
            "content": {
              "application/json": {
                "example": {
                  "status": "success",
                  "payload": {
                    "_id": "64b2d8f9e9a1b2c3d4e5f678",
                    "first_name": "Alejo",
                    "last_name": "Perez",
                    "email": "alejo@example.com",
                    "role": "user",
                    "pets": []
                  }
                }
              }
            }
          },
          "404": {
            "description": "Usuario no encontrado",
            "content": { "application/json": { "example": { "status": "error", "error": "User not found" } } }
          },
          "400": {
            "description": "ID inválido",
            "content": { "application/json": { "example": { "status": "error", "error": "Invalid ID" } } }
          }
        }
      },
      "put": {
        "summary": "Actualizar un usuario",
        "description": "Actualiza los campos permitidos de un usuario.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserInput"
              },
              "example": {
                "first_name": "Nuevo",
                "last_name": "Nombre",
                "email": "nuevo@example.com",
                "role": "user",
                "pets": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuario actualizado",
            "content": { "application/json": { "example": { "status": "success", "message": "User updated" } } }
          },
          "400": { "description": "Datos incompletos o inválidos", "content": { "application/json": { "example": { "status": "error", "error": "Incomplete values" } } } },
          "404": { "description": "Usuario no encontrado", "content": { "application/json": { "example": { "status": "error", "error": "User not found" } } } },
          "500": { "description": "Error del servidor", "content": { "application/json": { "example": { "status": "error", "error": "Internal Server Error" } } } }
        }
      },
      "delete": {
        "summary": "Eliminar un usuario",
        "description": "Elimina (o marca como eliminado) un usuario por ID.",
        "responses": {
          "200": { "description": "Usuario eliminado", "content": { "application/json": { "example": { "status": "success", "message": "User deleted" } } } },
          "404": { "description": "Usuario no encontrado", "content": { "application/json": { "example": { "status": "error", "error": "User not found" } } } },
          "400": { "description": "ID inválido", "content": { "application/json": { "example": { "status": "error", "error": "Invalid ID" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string" },
          "pets": { "type": "array", "items": { "type": "string" } }
        }
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string" },
          "pets": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["first_name","last_name","email"]
      }
    }
  }
}
